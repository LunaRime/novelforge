// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.novelforge.ide",
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*",
    "node_modules/@lancedb/lancedb/**/*",
    "node_modules/apache-arrow/**/*",
    "node_modules/@lancedb/lancedb-darwin-*/**/*",
    "node_modules/@lancedb/lancedb-linux-*/**/*",
    "node_modules/@lancedb/lancedb-win32-*/**/*"
  ],
  // 覆盖根 package.json 的 "type":"module"，确保主进程以 CommonJS 运行
  // Electron 主进程使用 CJS require，ESM 模式会导致 Rolldown CJS shim 崩溃
  "extraMetadata": {
    "main": "dist-electron/main.js",
    "type": "commonjs"
  },
  "productName": "NovelForge",
  "directories": {
    "output": "release/${version}"
  },
  // files 白名单 — electron-builder 按顺序评估，先排除后回加
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "build/**/*",
    "index.html",
    // 排除项
    "!src",
    "!electron",
    "!.git",
    "!.github",
    "!.storybook",
    "!.vscode",
    "!.idea",
    "!.claude",
    "!.codewhale-plans",
    "!tests",
    "!docs",
    "!release",
    "!*.md",
    "!tsconfig.json",
    "!tsconfig.node.json",
    "!vite.config.ts",
    "!pnpm-lock.yaml",
    "!pnpm-workspace.yaml",
    "!.gitignore",
    "!.npmignore",
    "!.npmrc",
    "!package.json",
    "!node_modules/.cache",
    "!node_modules/**",
    // 回加：external 依赖（Rolldown 无法打包的原生模块 + 其 JS 入口）
    "node_modules/better-sqlite3/**",
    "node_modules/@lancedb/lancedb/**",
    "node_modules/@lancedb/lancedb-win32-*/**",
    "node_modules/@lancedb/lancedb-darwin-*/**",
    "node_modules/@lancedb/lancedb-linux-*/**",
    "node_modules/apache-arrow/**",
    "node_modules/flatbuffers/**",
    "node_modules/tslib/**",
    "node_modules/reflect-metadata/**"
  ],
  "mac": {
    "target": ["dmg"],
    "artifactName": "${productName}-${version}-macOS.${ext}",
    "category": "public.app-category.productivity"
  },
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "artifactName": "${productName}-${version}-Installer/${productName}-${version}-Installer.${ext}",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "target": ["AppImage"],
    "artifactName": "${productName}-${version}-linux.${ext}",
    "category": "Office"
  },
  "publish": {
    "provider": "github",
    "owner": "LunaRime",
    "repo": "novelforge"
  }
}
